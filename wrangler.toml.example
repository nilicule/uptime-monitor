name = "uptime-monitor"
main = "src/worker.js"
compatibility_date = "2024-09-23"
compatibility_flags = ["nodejs_compat"]

[triggers]
crons = ["*/5 * * * *"]

[[kv_namespaces]]
binding = "UPTIME_KV"
id = "placeholder"
preview_id = "placeholder"

# Optional: uncomment to enable email notifications via Cloudflare Email Workers.
# Requires Cloudflare Email Routing to be configured on your domain.
# See docs/notifications.md for setup instructions.
# [[send_email]]
# name = "EMAIL"
